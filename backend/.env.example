# Warehouse Agent System — Environment Configuration
# Copy to .env and fill in values

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Bind address (127.0.0.1 for local dev, 0.0.0.0 to expose on LAN)
HOST=127.0.0.1

# Optional API key — if set, all POST/DELETE endpoints require X-API-Key header
API_KEY=

# LLM Configuration (optional — required only for --mode llm)
LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Database
DB_PATH=./warehouse.db

# Data directory
DATA_DIR=./data/generated
